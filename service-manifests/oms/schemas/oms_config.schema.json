{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OMS Service Config",
  "type": "object",
  "properties": {
    "nats_url": { "type": "string" },
    "redis_url": { "type": "string" },
    "pg_url": { "type": "string" },
    "oms_id": { "type": "string" },
    "grpc_port": { "type": "integer", "minimum": 1, "maximum": 65535 },
    "grpc_host": { "type": "string" },
    "handle_external_orders": { "type": "boolean" },
    "risk_check_enabled": { "type": "boolean" },
    "max_pending_reports": { "type": "integer", "minimum": 1 },
    "max_cached_orders": { "type": "integer", "minimum": 1 },
    "cmd_channel_buf": { "type": "integer", "minimum": 1 },
    "kv_heartbeat_secs": { "type": "integer", "minimum": 1 },
    "gateway_kv_prefix": { "type": "string" },
    "bootstrap_token": { "type": "string" },
    "instance_type": { "type": "string" },
    "env": { "type": "string" },
    "order_resync_interval_secs": { "type": "integer", "minimum": 1 },
    "balance_resync_interval_secs": { "type": "integer", "minimum": 1 },
    "position_recheck_interval_secs": { "type": "integer", "minimum": 1 },
    "cleanup_interval_secs": { "type": "integer", "minimum": 1 },
    "gw_exec_shard_count": { "type": "integer", "minimum": 1 },
    "gw_exec_queue_capacity": { "type": "integer", "minimum": 1 },
    "metrics_interval_secs": { "type": "integer", "minimum": 1 },
    "metrics_max_pending": { "type": "integer", "minimum": 1 },
    "metrics_max_complete": { "type": "integer", "minimum": 1 }
  },
  "required": ["oms_id", "redis_url", "pg_url"],
  "additionalProperties": true
}
