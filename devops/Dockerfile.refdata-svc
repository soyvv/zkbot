FROM python:3.11-slim-bookworm

RUN pip install --no-cache-dir uv

WORKDIR /app

COPY services/zk-refdata-svc/pyproject.toml ./
RUN uv pip install --system --no-cache \
    "grpcio>=1.62" \
    "protobuf>=4.25" \
    "asyncpg>=0.29" \
    "nats-py>=2.6" \
    "loguru>=0.7"

# Source includes pre-generated gRPC stubs (refdata_pb2.py / refdata_pb2_grpc.py)
COPY services/zk-refdata-svc/src ./src

ENV PYTHONPATH=/app/src

EXPOSE 50052

CMD ["python", "-m", "zk_refdata_svc.main"]
